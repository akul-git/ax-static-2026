---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import menu from '../data/menu.json';
import '../assets/css/icon-fonts.css';
type MenuLink = { label: string; href: string };
type MenuItem = MenuLink & { children?: MenuLink[] };

interface Props {
  title?: string;
}

const { title: pageTitle }: Props = Astro.props;

const normalizePath = (path?: string) => (path || '/').replace(/\/$/, '') || '/';
const currentPath = normalizePath(Astro.url.pathname);
const safeMenu: MenuItem[] = Array.isArray(menu) ? (menu as MenuItem[]) : [];

const allMenuLinks: MenuLink[] = safeMenu.flatMap((item) => {
  const links: MenuLink[] = [{ label: item.label, href: item.href }];
  if (Array.isArray(item.children) && item.children.length > 0) {
    links.push(...item.children);
  }
  return links;
});

const matchedLink = allMenuLinks.find((link) => normalizePath(link.href) === currentPath);
const resolvedTitle = pageTitle || matchedLink?.label || 'Asset Analytix';
const documentTitle = resolvedTitle === 'Asset Analytix' ? resolvedTitle : `${resolvedTitle} | Asset Analytix`;
---
<!doctype html>
<html lang="en" class="overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{documentTitle}</title>
    <slot name="head" />
     <link rel="stylesheet" href="/icons/businesspeople/style.css" />
      <link rel="stylesheet" href="/icons/style.css" />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden bg-neutral-100 text-slate-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
