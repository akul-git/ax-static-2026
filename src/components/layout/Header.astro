---
import Navigation from "../layout/Navigation.astro";
import axLogo from "../../assets/asset-analytix-logo.svg";
---
<header
  data-site-header
  class="sticky top-0 z-120 bg-white transition-all duration-300 ease-out"
>
  <div class="container mx-auto flex justify-between items-center py-4 px-6">
    <a href="/"><img src={axLogo.src} width="206" height="54" alt="AX Homepage" /></a>
    <Navigation />
  </div>
</header>

<script>
  const initHeaderScroll = () => {
    const header = document.querySelector("[data-site-header]");
    if (!(header instanceof HTMLElement) || header.dataset.headerBound === "true") return;
    header.dataset.headerBound = "true";

    let ticking = false;
    const stickAt = 300;

    const update = () => {
      const currentY = window.scrollY;

      if (currentY >= stickAt) {
        header.classList.add("shadow-md");
      } else {
        header.classList.remove("shadow-md");
      }

      ticking = false;
    };

    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
  };

  initHeaderScroll();
  document.addEventListener("DOMContentLoaded", initHeaderScroll);
  document.addEventListener("astro:page-load", initHeaderScroll);
</script>
