---
type DropdownItem = {
  href: string;
  title: string;
};

type Props = {
  label?: string;
  items?: DropdownItem[];
};

const { label = "Menu", items = [] } = Astro.props as Props;
---
<details class="group relative inline-block text-left">
  <summary class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-900 shadow-sm transition hover:bg-slate-50">
    {label}
    <span class="text-slate-500">▾</span>
  </summary>
  <div class="invisible absolute left-0 z-10 mt-2 min-w-56 rounded-3xl border border-slate-200 bg-white p-3 opacity-0 shadow-xl transition-all duration-200 group-open:visible group-open:opacity-100">
    {items.map((item) => (
      <a
        href={item.href}
        class="block rounded-2xl px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900"
      >
        {item.title}
      </a>
    ))}
  </div>
</details>
