---
type TypographyVariant = "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "body" | "small" | "label" | "lead";
type TypographyTag = "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p";

type Props = {
  as?: TypographyTag;
  variant?: TypographyVariant;
  class?: string;
  id?: string;
};

const {
  as = "p",
  variant = "body",
  class: className = "",
  id,
} = Astro.props as Props;

const variants = {
  h1: "text-4xl md:text-[2.25rem] leading-tight font-bold tracking-tight text-slate-900",
  h2: "text-3xl md:text-[1.75rem] leading-tight font-semibold tracking-tight text-slate-900",
  h3: "text-xl md:text-[1.25rem] leading-snug font-semibold text-slate-900",
  h4: "text-base md:text-[1rem] font-semibold text-slate-900",
  h5: "text-sm md:text-[0.9rem] font-medium text-slate-800",
  h6: "text-sm font-medium uppercase tracking-[0.18em] text-slate-600",
  body: "text-base leading-7 text-slate-700",
  small: "text-sm leading-6 text-slate-600",
  label: "text-sm uppercase tracking-[0.18em] text-slate-600",
  lead: "text-lg leading-8 text-slate-700",
} as const;

const tag = as;
const variantKey: TypographyVariant = variant in variants ? variant : "body";
const classes = `${variants[variantKey] ?? variants.body} ${className}`.trim();
---
{tag === "h1" ? (
  <h1 id={id} class={classes}><slot /></h1>
) : tag === "h2" ? (
  <h2 id={id} class={classes}><slot /></h2>
) : tag === "h3" ? (
  <h3 id={id} class={classes}><slot /></h3>
) : tag === "h4" ? (
  <h4 id={id} class={classes}><slot /></h4>
) : tag === "h5" ? (
  <h5 id={id} class={classes}><slot /></h5>
) : tag === "h6" ? (
  <h6 id={id} class={classes}><slot /></h6>
) : (
  <p id={id} class={classes}><slot /></p>
)}
