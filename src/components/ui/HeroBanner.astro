---
const {
  class: className = "",
  title = "",
  subtitle = "",
  backgroundImage = "",
  backgroundAlt = "Banner image",
  variant = "banner",
  overlay = "rgba(15, 23, 42, 0.45)",
  align = "center",
} = Astro.props;

const isHero = variant === "hero";
const minHeightClass = isHero ? "min-h-[24rem] sm:min-h-[26rem]" : "min-h-[16rem] sm:min-h-[18rem]";
const flexClass = align === "left" ? "items-center justify-start text-left" : "items-center justify-center text-center";
---

<section class={`relative overflow-hidden rounded-sm w-full ${minHeightClass} flex items-center justify-center ${className}`.trim()} aria-label="Hero banner">
  {backgroundImage ? (
    <img src={backgroundImage} alt={backgroundAlt} class="absolute inset-0 h-full w-full object-cover" loading="eager" />
  ) : null}

  <div class="absolute inset-0" style={`background:${overlay};`}></div>

  <div class="relative z-10 px-6 sm:px-10">
    <div class={`${align === "left" ? "text-left max-w-3xl" : "text-center max-w-4xl"}`}>
      {title ? (
        <h1 class={`${isHero ? "text-5xl sm:text-6xl" : "text-5xl sm:text-6xl"} font-medium text-white drop-shadow-sm`}>
          {title}
        </h1>
      ) : null}
      {subtitle ? (
        <p class={`${isHero ? "mt-4 text-xl sm:text-2xl" : "mt-3 text-lg sm:text-xl"} font-medium leading-relaxed text-white`}>
          {subtitle}
        </p>
      ) : null}
      <div class="mt-6">
        <slot />
      </div>
    </div>
  </div>
</section>
