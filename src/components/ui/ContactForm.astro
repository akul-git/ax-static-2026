---
const {
  class: className = "",
  action = String(import.meta.env.PUBLIC_CONTACT_FORM_ACTION || ""),
  method = "post",
  submitLabel = "Submit",
  newsletterLabel = "Yes, I would like to receive updates from Asset Analytix",
  showCaptchaPlaceholder = true,
} = Astro.props;

const publicCaptchaProvider = String(import.meta.env.PUBLIC_CAPTCHA_PROVIDER || "").toLowerCase();
const recaptchaSiteKey = String(import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || "");
const hcaptchaSiteKey = String(import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY || "");
const captchaProvider = publicCaptchaProvider === "hcaptcha" ? "hcaptcha" : publicCaptchaProvider === "recaptcha" ? "recaptcha" : "";
const activeSiteKey = captchaProvider === "hcaptcha" ? hcaptchaSiteKey : recaptchaSiteKey;
const hasLiveCaptcha = Boolean(captchaProvider && activeSiteKey);
---

<form
  data-contact-form
  data-form-action={action}
  data-captcha-provider={captchaProvider}
  data-site-key={activeSiteKey}
  class={`rounded-sm bg-slate-100 p-6 shadow-sm sm:p-8 ${className}`.trim()}
  action={action}
  method={method}
  accept-charset="UTF-8"
>
  {!action ? (
    <p class="mb-6 rounded-sm border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      Contact form endpoint is not configured. Set <strong>PUBLIC_CONTACT_FORM_ACTION</strong> to enable submissions on static hosting.
    </p>
  ) : null}

  <input type="hidden" name="form_name" value="contact-us" />
  <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
  <input type="hidden" name="captchaToken" value="" />
  <input type="hidden" name="g-recaptcha-response" value="" />
  <input type="hidden" name="h-captcha-response" value="" />

  <div class="grid gap-6 sm:grid-cols-2">
    <div>
      <label for="firstName" class="block text-lg font-semibold text-slate-800">Name <span class="text-red-500">*</span></label>
      <input id="firstName" name="firstName" type="text" maxlength="80" required autocomplete="given-name" class="mt-3 w-full rounded-sm border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-600 focus:ring-2 focus:ring-sky-200" />
      <p class="mt-2 text-sm text-slate-600">First</p>
    </div>
    <div class="sm:pt-8">
      <label for="lastName" class="sr-only">Last name</label>
      <input id="lastName" name="lastName" type="text" maxlength="80" required autocomplete="family-name" class="mt-3 w-full rounded-sm border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-600 focus:ring-2 focus:ring-sky-200 sm:mt-0" />
      <p class="mt-2 text-sm text-slate-600">Last</p>
    </div>
  </div>

  <div class="mt-6">
    <label for="companyName" class="block text-lg font-semibold text-slate-800">Company Name <span class="text-red-500">*</span></label>
    <input id="companyName" name="companyName" type="text" maxlength="140" required autocomplete="organization" class="mt-3 w-full rounded-sm border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-600 focus:ring-2 focus:ring-sky-200" />
  </div>

  <div class="mt-6">
    <label for="jobTitle" class="block text-lg font-semibold text-slate-800">Job Title <span class="text-red-500">*</span></label>
    <input id="jobTitle" name="jobTitle" type="text" maxlength="140" required autocomplete="organization-title" class="mt-3 w-full rounded-sm border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-600 focus:ring-2 focus:ring-sky-200" />
  </div>

  <div class="mt-6">
    <label for="workEmail" class="block text-lg font-semibold text-slate-800">Work Email <span class="text-red-500">*</span></label>
    <input id="workEmail" name="workEmail" type="email" maxlength="254" required autocomplete="email" inputmode="email" class="mt-3 w-full rounded-sm border border-slate-300 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-sky-600 focus:ring-2 focus:ring-sky-200" />
  </div>

  <div class="mt-8">
    <p class="text-lg text-red-500">*</p>
    <label class="mt-2 inline-flex items-start gap-3 text-lg text-slate-700">
      <input type="checkbox" name="newsletter" value="yes" class="mt-1 h-5 w-5 rounded border-slate-300 text-sky-700 focus:ring-sky-600" />
      <span>{newsletterLabel}</span>
    </label>
  </div>

  {hasLiveCaptcha ? (
    <div class="mt-8 max-w-sm rounded-sm border border-slate-300 bg-white p-4 shadow-xs">
      <div data-captcha-widget class="min-h-20"></div>
      <p data-captcha-error class="mt-3 hidden text-sm font-medium text-rose-700">
        Please complete CAPTCHA verification before submitting.
      </p>
    </div>
  ) : showCaptchaPlaceholder ? (
    <div class="mt-8 max-w-sm rounded-sm border border-slate-300 bg-white p-4 shadow-xs">
      <div class="flex items-center justify-between gap-4">
        <label class="flex items-center gap-3 text-lg text-slate-800">
          <span class="flex h-8 w-8 items-center justify-center border-2 border-slate-500 bg-white"></span>
          <span>I'm not a robot</span>
        </label>
        <div class="text-right text-xs text-slate-500">
          <div class="font-semibold text-slate-600">reCAPTCHA</div>
          <div>Connect live key here</div>
        </div>
      </div>
    </div>
  ) : null}

  <div class="mt-8">
    <button type="submit" disabled={!action} class="inline-flex rounded-sm bg-sky-700 px-6 py-3 text-lg font-semibold text-white transition hover:bg-sky-600 disabled:cursor-not-allowed disabled:opacity-50">{submitLabel}</button>
  </div>
</form>

<script>
  const initContactCaptcha = () => {
    const win = window;
    const winAny = /** @type {any} */ (window);

    document.querySelectorAll("[data-contact-form]").forEach((form) => {
      if (!(form instanceof HTMLFormElement) || form.dataset.captchaBound === "true") return;
      form.dataset.captchaBound = "true";

      if (!form.dataset.formAction) {
        return;
      }

      const provider = form.dataset.captchaProvider || "";
      const siteKey = form.dataset.siteKey || "";
      const widgetHost = form.querySelector("[data-captcha-widget]");
      const errorText = form.querySelector("[data-captcha-error]");
      const tokenInput = form.querySelector("input[name='captchaToken']");
      const recaptchaInput = form.querySelector("input[name='g-recaptcha-response']");
      const hcaptchaInput = form.querySelector("input[name='h-captcha-response']");
      const submitButton = form.querySelector("button[type='submit']");

      if (!(widgetHost instanceof HTMLElement) || !provider || !siteKey) return;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      const setToken = (tokenValue = "") => {
        const safeToken = String(tokenValue || "");
        if (tokenInput instanceof HTMLInputElement) tokenInput.value = safeToken;
        if (recaptchaInput instanceof HTMLInputElement) recaptchaInput.value = provider === "recaptcha" ? safeToken : "";
        if (hcaptchaInput instanceof HTMLInputElement) hcaptchaInput.value = provider === "hcaptcha" ? safeToken : "";
        if (errorText instanceof HTMLElement) {
          errorText.classList.toggle("hidden", Boolean(safeToken));
        }
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = !Boolean(safeToken);
        }
      };

      const loadRecaptchaScript = () =>
        new Promise((resolve, reject) => {
          const scriptUrl = "https://www.google.com/recaptcha/api.js?render=explicit";
          const existing = document.querySelector(`script[src="${scriptUrl}"]`);
          if (existing) {
            if (existing.getAttribute("data-loaded") === "true") {
              resolve(true);
            } else {
              existing.addEventListener("load", () => resolve(true), { once: true });
              existing.addEventListener("error", () => reject(new Error("captcha_script_error")), { once: true });
            }
            return;
          }

          const script = document.createElement("script");
          script.src = scriptUrl;
          script.async = true;
          script.defer = true;
          script.addEventListener("load", () => {
            script.setAttribute("data-loaded", "true");
            resolve(true);
          });
          script.addEventListener("error", () => reject(new Error("captcha_script_error")));
          document.head.appendChild(script);
        });

      const loadHCaptchaScript = () =>
        new Promise((resolve, reject) => {
          const scriptUrl = "https://js.hcaptcha.com/1/api.js?render=explicit";
          const existing = document.querySelector(`script[src="${scriptUrl}"]`);
          if (existing) {
            if (existing.getAttribute("data-loaded") === "true") {
              resolve(true);
            } else {
              existing.addEventListener("load", () => resolve(true), { once: true });
              existing.addEventListener("error", () => reject(new Error("captcha_script_error")), { once: true });
            }
            return;
          }

          const script = document.createElement("script");
          script.src = scriptUrl;
          script.async = true;
          script.defer = true;
          script.addEventListener("load", () => {
            script.setAttribute("data-loaded", "true");
            resolve(true);
          });
          script.addEventListener("error", () => reject(new Error("captcha_script_error")));
          document.head.appendChild(script);
        });

      const renderCaptcha = async () => {
        try {
          if (provider === "recaptcha") {
            await loadRecaptchaScript();
            // @ts-ignore runtime global injected by Google script
            const recaptcha = winAny.grecaptcha;
            if (!recaptcha || typeof recaptcha.render !== "function") return;
            recaptcha.render(widgetHost, {
              sitekey: siteKey,
              callback: (receivedToken = "") => setToken(receivedToken),
              "expired-callback": () => setToken(""),
            });
            return;
          }

          if (provider === "hcaptcha") {
            await loadHCaptchaScript();
            // @ts-ignore runtime global injected by hCaptcha script
            const hcaptcha = winAny.hcaptcha;
            if (!hcaptcha || typeof hcaptcha.render !== "function") return;
            hcaptcha.render(widgetHost, {
              sitekey: siteKey,
              callback: (receivedToken = "") => setToken(receivedToken),
              "expired-callback": () => setToken(""),
            });
          }
        } catch {
          if (errorText instanceof HTMLElement) {
            errorText.textContent = "Captcha failed to load. Please refresh and retry.";
            errorText.classList.remove("hidden");
          }
        }
      };

      renderCaptcha();
    });
  };

  initContactCaptcha();
  document.addEventListener("DOMContentLoaded", initContactCaptcha);
  document.addEventListener("astro:page-load", initContactCaptcha);
</script>
