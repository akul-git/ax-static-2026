---
type Level = 1 | 2 | 3 | 4 | 5 | 6;

type Props = {
  level?: Level;
  class?: string;
};

const {
  level = 2,
  class: className = "",
} = Astro.props as Props;

const styles = {
  1: "text-4xl md:text-5xl lg:text-6xl font-light leading-tight tracking-tight",
  2: "text-3xl md:text-4xl lg:text-5xl  tracking-tight",
  3: "text-2xl md:text-3xl lg:text-4xl font-medium leading-tight",
  4: "text-xl md:text-2xl lg:text-3xl font-semibold",
  5: "text-lg md:text-xl lg:text-2xl font-semibold leading-snug",
  6: "text-base md:text-lg lg:text-xl font-semibold leading-normal",
} as const;

const classes = `${styles[level]} text-brand ${className}`.trim();

const Tag = `h${level}` as keyof HTMLElementTagNameMap;
---

<Tag class={classes}>
  <slot />
</Tag>