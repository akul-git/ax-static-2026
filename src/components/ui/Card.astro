---
import { titleVariants, linkVariants } from "../../lib/theme";

type TitleVariant = keyof typeof titleVariants;

type TitleLine = {
  text: string;
  variant?: TitleVariant;
};

type CardProps = {
  class?: string;
  eyebrow?: string;
  title?: string | TitleLine[];
  description?: string;
  href?: string;
  linkLabel?: string;
};

const {
  class: className = "",
  eyebrow = "",
  title = [],
  description = "",
  href = "",
  linkLabel = "Learn More",
} = Astro.props as CardProps;

const normalizedTitle: TitleLine[] =
  typeof title === "string"
    ? [{ text: title, variant: "brand" }]
    : title;

const hasStructuredContent =
  eyebrow ||
  normalizedTitle.length ||
  description ||
  href;
---

<article
  class={`rounded border border-slate-200 bg-white p-4 sm:p-6 shadow-lg  ${className}`.trim()}
>
  {hasStructuredContent ? (
    <>
      {eyebrow && (
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-700 mt-0!">
          <span class="mr-3 inline-block h-0.5 w-10 bg-accent align-middle"></span>
          {eyebrow}
        </p>
      )}

      {normalizedTitle.length > 0 && (
        <h4 class="text-xl sm:text-2xl md:text-3xl font-semibold">
          {normalizedTitle.map((line: TitleLine) => (
            <span
              class:list={[
                "block",
                titleVariants[line.variant ?? "brand"],
              ]}
            >
              {line.text}
            </span>
          ))}
        </h4>
      )}

      {description && (
        <p class="mt-4  text-slate-700">
          {description}
        </p>
      )}

      {href && (
        <a
          href={href}
          class:list={[
            "mt-6 inline-flex items-center gap-2 text-lg font-semibold transition-colors duration-200",
            linkVariants.accent,
          ]}
        >
          {linkLabel}
          <span aria-hidden="true">&raquo;</span>
        </a>
      )}
    </>
  ) : (
    <slot />
  )}
</article>