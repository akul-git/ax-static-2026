---
const {
  class: className = "",
  eyebrow = "",
  title = "",
  description = "",
  href = "",
  linkLabel = "Learn more",
} = Astro.props;

const hasStructuredContent = Boolean(eyebrow || title || description || href);
---
<article class={`rounded-3xl border border-slate-200 bg-white p-6 shadow-sm ${className}`.trim()}>
  {hasStructuredContent ? (
    <>
      {eyebrow ? (
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">
          <span class="mr-3 inline-block h-0.5 w-10 align-middle bg-sky-600"></span>{eyebrow}
        </p>
      ) : null}
      {title ? <h4 class="text-4xl leading-tight font-semibold text-sky-800">{title}</h4> : null}
      {description ? <p class="mt-4 text-xl leading-8 text-slate-700">{description}</p> : null}
      {href ? (
        <a href={href} class="mt-6 inline-flex items-center gap-2 text-lg font-semibold text-sky-700 hover:text-sky-600">
          {linkLabel}
          <span aria-hidden="true">&raquo;</span>
        </a>
      ) : null}
    </>
  ) : (
    <slot />
  )}
</article>
