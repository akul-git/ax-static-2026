---
import Button from "./Button.astro";

const {
  class: className = "",
  backgroundImage = "",
  backgroundAlt = "Book a demo background",
  href = "/book-demo",
  buttonLabel = "BOOK A DEMO",
  overlay = "linear-gradient(90deg, rgba(2,132,199,0.22), rgba(15,23,42,0.24))",
  minHeight = "18rem",
} = Astro.props;
---

<section
  class={`group relative overflow-hidden rounded-sm ${className}`.trim()}
  style={`min-height:${minHeight};`}
  aria-label="Book a demo"
>
  {backgroundImage ? (
    <img
      src={backgroundImage}
      alt={backgroundAlt}
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />
  ) : null}

  <div class="absolute inset-0" style={`background:${overlay};`}></div>

  <div class="relative z-10 flex min-h-[inherit] items-center justify-center px-6 py-8">
    <Button
      href={href}
      class="rounded-lg bg-sky-600 px-12 py-4 text-4xl font-bold tracking-wide text-white shadow-lg hover:bg-sky-500"
    >
      {buttonLabel}
    </Button>
  </div>
</section>
