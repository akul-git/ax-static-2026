---
import "mediaelement/build/mediaelementplayer.min.css";

const {
  class: className = "",
  title = "Video",
  src = "",
  embedUrl = "",
  mediaType = "auto",
  poster = "",
  caption = "",
  controls = true,
  autoplay = false,
  loop = false,
  muted = false,
} = Astro.props;

const isAudioSource = typeof src === "string" && /\.(mp3|m4a|aac|wav|ogg)(\?|#|$)/i.test(src);
const resolvedMediaType = mediaType === "auto" ? (isAudioSource ? "audio" : "video") : mediaType;
const isAudio = resolvedMediaType === "audio";
---

<section
  class={`overflow-hidden rounded-2xl border border-slate-200 ${
    isAudio ? "bg-white" : "bg-slate-950"
  } shadow-sm ${className}`.trim()}
>
  <div class={isAudio ? "w-full p-4" : "aspect-video w-full"}>
    {embedUrl ? (
      <iframe
        class="h-full w-full"
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    ) : isAudio ? (
      <audio
        class="mejs__player w-full"
        data-ax-mediaelement
        data-mejsoptions='{"stretching":"responsive","features":["playpause","progress","current","duration","volume"]}'
        src={src}
        controls={controls}
        autoplay={autoplay}
        loop={loop}
        muted={muted}
        preload="metadata"
      >
        Your browser does not support the audio tag.
      </audio>
    ) : (
      <video
        class="mejs__player h-full w-full object-cover"
        data-ax-mediaelement
        data-mejsoptions='{"stretching":"responsive","features":["playpause","progress","current","duration","volume","fullscreen"]}'
        src={src}
        poster={poster}
        controls={controls}
        autoplay={autoplay}
        loop={loop}
        muted={muted}
        playsinline
        preload="metadata"
      >
        Your browser does not support the video tag.
      </video>
    )}
  </div>
  {caption ? <p class="border-t border-slate-800 bg-slate-900 px-4 py-3 text-sm text-slate-200">{caption}</p> : null}
</section>

<script type="module">
  import "mediaelement/full";

  const initMediaElements = () => {
    const Player = window.MediaElementPlayer;
    if (!Player) return;

    document.querySelectorAll("video[data-ax-mediaelement], audio[data-ax-mediaelement]").forEach((node) => {
      if (!(node instanceof HTMLMediaElement) || node.dataset.meBound === "true") return;
      node.dataset.meBound = "true";
      const optionsRaw = node.dataset.mejsoptions;
      const parsedOptions = optionsRaw ? JSON.parse(optionsRaw) : {};
      new Player(node, {
        ...parsedOptions,
        stretching: "responsive",
      });
    });
  };

  initMediaElements();
  document.addEventListener("DOMContentLoaded", initMediaElements);
  document.addEventListener("astro:page-load", initMediaElements);
</script>
