---
type LogoItem = { src: string; alt: string; href?: string };

const {
  class: className = "",
  logos = [],
  interval = 4000,
  mobileItemsPerSlide = 2,
  tabletItemsPerSlide = 3,
  desktopItemsPerSlide = 4,
} = Astro.props;

const safeLogos: LogoItem[] = Array.isArray(logos) ? (logos as LogoItem[]) : [];
---

<section
  data-client-logo-slider
  data-interval={String(interval)}
  data-mobile-items={String(mobileItemsPerSlide)}
  data-tablet-items={String(tabletItemsPerSlide)}
  data-desktop-items={String(desktopItemsPerSlide)}
  class={`relative  px-16 py-8 ${className}`.trim()}
  aria-label="Client logo slider"
>
  <button type="button" class="ax-client-prev absolute left-4 top-1/2 -translate-y-1/2 text-slate-700 transition hover:text-sky-700" aria-label="Previous logos">
    <svg class="h-9 w-9" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="overflow-hidden">
    <div class="ax-client-track">
      {
        safeLogos.map((logo) => (
          <div class="px-4">
            <div class="flex min-h-20 w-full items-center justify-center">
              {logo.href ? (
                <a href={logo.href} class="flex items-center justify-center" aria-label={logo.alt}>
                  <img src={logo.src} alt={logo.alt} loading="lazy" class="h-20 w-auto max-w-full object-contain opacity-90 transition hover:opacity-100" />
                </a>
              ) : (
                <img src={logo.src} alt={logo.alt} loading="lazy" class="h-20 w-auto max-w-full object-contain opacity-90 transition hover:opacity-100" />
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <button type="button" class="ax-client-next absolute right-4 top-1/2 -translate-y-1/2 text-slate-700 transition hover:text-sky-700" aria-label="Next logos">
    <svg class="h-9 w-9" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>
</section>

<script>
  const initLogoSlider = async () => {
    if (typeof window === "undefined") return;

    const jqueryModule = await import("jquery");
    const $ = jqueryModule.default;
    (window as Window & { $?: typeof $; jQuery?: typeof $ }).$ = $;
    (window as Window & { $?: typeof $; jQuery?: typeof $ }).jQuery = $;
    await import("slick-carousel");

    document.querySelectorAll("[data-client-logo-slider]").forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.logoBound === "true") return;
      root.dataset.logoBound = "true";

      const track = root.querySelector(".ax-client-track");
      const prev = root.querySelector(".ax-client-prev");
      const next = root.querySelector(".ax-client-next");

      if (!(track instanceof HTMLElement)) return;
      const intervalMs = Number(root.getAttribute("data-interval")) || 4000;
      const mobileItems = Math.max(1, Number(root.getAttribute("data-mobile-items")) || 2);
      const tabletItems = Math.max(1, Number(root.getAttribute("data-tablet-items")) || 3);
      const desktopItems = Math.max(1, Number(root.getAttribute("data-desktop-items")) || 4);
      const $track = $(track);

      if (track.children.length === 0) return;

      try {
        if ($track.hasClass("slick-initialized")) {
          $track.slick("unslick");
        }

        $track.slick({
          slidesToShow: desktopItems,
          slidesToScroll: 1,
          autoplay: true,
          autoplaySpeed: intervalMs,
          arrows: true,
          prevArrow: prev instanceof HTMLElement ? prev : undefined,
          nextArrow: next instanceof HTMLElement ? next : undefined,
          dots: false,
          infinite: true,
          pauseOnHover: true,
          pauseOnFocus: true,
          responsive: [
            {
              breakpoint: 1024,
              settings: {
                slidesToShow: tabletItems,
              },
            },
            {
              breakpoint: 640,
              settings: {
                slidesToShow: mobileItems,
              },
            },
          ],
        });
      } catch {
        root.dataset.logoBound = "false";
      }
    });
  };

  initLogoSlider();
  document.addEventListener("DOMContentLoaded", initLogoSlider);
  document.addEventListener("astro:page-load", initLogoSlider);
</script>
