---
type LogoItem = { src: string; alt: string; href?: string };

const {
  class: className = "",
  logos = [],
  interval = 4000,
  itemsPerSlide = 4,
} = Astro.props;

const safeLogos: LogoItem[] = Array.isArray(logos) ? (logos as LogoItem[]) : [];
const safeItemsPerSlide = Math.max(1, Number(itemsPerSlide) || 4);
const logoGroups: LogoItem[][] = [];

for (let index = 0; index < safeLogos.length; index += safeItemsPerSlide) {
  logoGroups.push(safeLogos.slice(index, index + safeItemsPerSlide));
}
---

<section data-client-logo-slider class={`relative rounded-sm border border-slate-200 bg-slate-100 px-16 py-8 ${className}`.trim()} aria-label="Client logo slider">
  <button type="button" class="ax-client-prev absolute left-4 top-1/2 -translate-y-1/2 text-slate-700 transition hover:text-sky-700" aria-label="Previous logos">
    <svg class="h-9 w-9" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>

  <div class="overflow-hidden">
    <div class="ax-client-track flex transition-transform duration-700 ease-out">
      {logoGroups.map((group) => (
        <div class="min-w-full px-4">
          <ul class="grid min-h-24 grid-cols-2 items-center justify-items-center gap-8 md:grid-cols-4 md:gap-12">
            {group.map((logo) => (
              <li class="flex min-h-20 w-full items-center justify-center">
                {logo.href ? (
                  <a href={logo.href} class="flex items-center justify-center" aria-label={logo.alt}>
                    <img src={logo.src} alt={logo.alt} class="h-20 w-auto max-w-full object-contain opacity-90 transition hover:opacity-100" loading="lazy" />
                  </a>
                ) : (
                  <img src={logo.src} alt={logo.alt} class="h-20 w-auto max-w-full object-contain opacity-90" loading="lazy" />
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <button type="button" class="ax-client-next absolute right-4 top-1/2 -translate-y-1/2 text-slate-700 transition hover:text-sky-700" aria-label="Next logos">
    <svg class="h-9 w-9" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>
</section>

<script>
  const initLogoSlider = () => {
    document.querySelectorAll("[data-client-logo-slider]").forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.logoBound === "true") return;
      root.dataset.logoBound = "true";

      const track = root.querySelector(".ax-client-track");
      const prev = root.querySelector(".ax-client-prev");
      const next = root.querySelector(".ax-client-next");

      if (!(track instanceof HTMLElement)) return;

      const slides = Array.from(track.children);
      if (slides.length <= 1) return;

      let activeIndex = 0;
      let timer = -1;
      const intervalMs = Number(root.getAttribute("data-interval")) || 4000;

      const sync = () => {
        track.style.transform = `translateX(-${activeIndex * 100}%)`;
      };

      const startAutoplay = () => {
        stopAutoplay();
        timer = window.setInterval(() => {
          activeIndex = (activeIndex + 1 + slides.length) % slides.length;
          sync();
        }, intervalMs);
      };

      const stopAutoplay = () => {
        if (timer !== -1) {
          window.clearInterval(timer);
          timer = -1;
        }
      };

      prev?.addEventListener("click", () => {
        activeIndex = (activeIndex - 1 + slides.length) % slides.length;
        sync();
      });

      next?.addEventListener("click", () => {
        activeIndex = (activeIndex + 1 + slides.length) % slides.length;
        sync();
      });

      root.addEventListener("mouseenter", stopAutoplay);
      root.addEventListener("mouseleave", startAutoplay);

      sync();
      startAutoplay();
    });
  };

  initLogoSlider();
  document.addEventListener("DOMContentLoaded", initLogoSlider);
  document.addEventListener("astro:page-load", initLogoSlider);
</script>
