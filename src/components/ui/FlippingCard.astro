---
const {
  class: className = "",
  frontTitle = "",
  frontPreText = "",
  frontLogo = "",
  frontLogoAlt = "Logo",
  frontBottomText = "",
  frontImage = "",
  frontAlt = "Front image",
  backText = "",
  backImage = "",
  backAlt = "Back image",
  href = "",
  minHeight = "16rem",
} = Astro.props;
---

{
  href ? (
    <a href={href} class="block no-underline">
      <article
        class={`ax-flip-card ${className}`.trim()}
        style={`--ax-flip-min-height:${minHeight};`}
      >
        <div class="ax-flip-card__inner">
          <div class="ax-flip-card__face ax-flip-card__face--front">
            {frontImage ? (
              <img
                src={frontImage}
                alt={frontAlt}
                class="ax-flip-card__media"
              />
            ) : null}
            <div class="ax-flip-card__content">
              {frontTitle ? (
                <h4 class="whitespace-pre-line text-2xl font-semibold leading-tight text-sky-700">
                  {frontTitle}
                </h4>
              ) : null}
              <div class="mt-8 space-y-5">
                {frontPreText ? (
                  <p class="text-base text-sky-700">{frontPreText}</p>
                ) : null}
                {frontLogo ? (
                  <img
                    src={frontLogo}
                    alt={frontLogoAlt}
                    class="mx-auto h-auto max-w-42!"
                  />
                ) : null}
                {frontBottomText ? (
                  <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-800">
                    {frontBottomText}
                  </p>
                ) : null}
              </div>
            </div>
          </div>
          <div class="ax-flip-card__face ax-flip-card__face--back">
            {backImage ? (
              <img src={backImage} alt={backAlt} class="ax-flip-card__media" />
            ) : null}
            <div class="ax-flip-card__content">
              {backText ? (
                <p class="text-xl font-medium leading-8 text-sky-700">
                  {backText}
                </p>
              ) : (
                <slot />
              )}
            </div>
          </div>
        </div>
      </article>
    </a>
  ) : (
    <article
      class={`ax-flip-card ${className}`.trim()}
      style={`--ax-flip-min-height:${minHeight};`}
    >
      <div class="ax-flip-card__inner">
        <div class="ax-flip-card__face ax-flip-card__face--front">
          {frontImage ? (
            <img src={frontImage} alt={frontAlt} class="ax-flip-card__media" />
          ) : null}
          <div class="ax-flip-card__content">
            {frontTitle ? (
              <h4 class="whitespace-pre-line text-2xl font-semibold leading-tight text-sky-700">
                {frontTitle}
              </h4>
            ) : null}
            <div class="mt-8 space-y-5">
              {frontPreText ? (
                <p class="text-base text-sky-700">{frontPreText}</p>
              ) : null}
              {frontLogo ? (
                <img
                  src={frontLogo}
                  alt={frontLogoAlt}
                  class="mx-auto h-auto max-w-42!"
                />
              ) : null}
              {frontBottomText ? (
                <p class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-500">
                  {frontBottomText}
                </p>
              ) : null}
            </div>
          </div>
        </div>
        <div class="ax-flip-card__face ax-flip-card__face--back">
          {backImage ? (
            <img src={backImage} alt={backAlt} class="ax-flip-card__media" />
          ) : null}
          <div class="ax-flip-card__content">
            {backText ? (
              <p class="text-lg  leading-8 text-sky-700">
                {backText}
              </p>
            ) : (
              <slot />
            )}
          </div>
        </div>
      </div>
    </article>
  )
}

<style>
  .ax-flip-card {
    position: relative;
    min-height: var(--ax-flip-min-height, 16rem);
    border: 1px solid rgb(14 116 204 / 0.85);
    border-radius: 0.75rem;
    perspective: 1000px;
    background: #fff;
    overflow: hidden;
    isolation: isolate;
  }

  .ax-flip-card__inner {
    position: relative;
    min-height: inherit;
    transition: transform 420ms ease;
    transform-style: preserve-3d;
  }

  .ax-flip-card:hover .ax-flip-card__inner,
  .ax-flip-card:focus-within .ax-flip-card__inner {
    transform: rotateX(180deg);
  }

  .ax-flip-card__face {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    border-radius: inherit;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: #f8fafc;
  }

  .ax-flip-card__face--back {
    transform: rotateX(180deg);
  }

  .ax-flip-card__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
  }

  .ax-flip-card__content {
    position: relative;
    z-index: 1;
    max-width: 18rem;
    padding: 1.25rem;
    text-align: center;
  }
</style>
