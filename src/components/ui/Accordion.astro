---
type AccordionItem = {
  title: string;
  content?: string;
  bullets?: string[];
  open?: boolean;
};

type Props = {
  items: AccordionItem[];
  class?: string;
  allowMultiple?: boolean;
  openFirst?: boolean;
};

const {
  items = [],
  class: className = "",
  allowMultiple = false,
  openFirst = true,
} = Astro.props as Props;
---

<section
  class={`rounded-2xl border border-slate-300 bg-slate-100/60 px-4 sm:px-6 ${className}`.trim()}
  data-ax-accordion
  data-allow-multiple={allowMultiple ? "true" : "false"}
>
  {items.map((item, index) => {
    const isOpen = item.open ?? (openFirst && index === 0);
    const hasBody = Boolean(item.content) || (Array.isArray(item.bullets) && item.bullets.length > 0);

    return (
      <details class="group border-b border-slate-300 py-2 last:border-b-0" open={isOpen} data-ax-accordion-item>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-2 text-3xl font-normal tracking-tight text-sky-700 marker:content-none">
          <span>{item.title}</span>
          <svg
            class="h-5 w-5 shrink-0 text-slate-500 transition-transform duration-200 group-open:rotate-180"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </summary>

        {hasBody ? (
          <div data-ax-accordion-panel>
            <div class="pb-4 pr-0 text-lg leading-8 text-slate-800 sm:pr-10">
              {item.content ? <p>{item.content}</p> : null}
              {Array.isArray(item.bullets) && item.bullets.length > 0 ? (
                <ul class="mt-4 list-disc space-y-2 pl-6">
                  {item.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              ) : null}
            </div>
          </div>
        ) : null}
      </details>
    );
  })}
</section>

<script>
  const DURATION = 420;
  const EASING = "cubic-bezier(0.16, 1, 0.3, 1)";

  const getPanel = (item: HTMLDetailsElement | Element | null) => {
    if (!(item instanceof HTMLDetailsElement)) return null;
    const panel = item.querySelector("[data-ax-accordion-panel]");
    return panel instanceof HTMLElement ? panel : null;
  };

  const preparePanel = (item: HTMLDetailsElement) => {
    const panel = getPanel(item);
    if (!panel) return;

    panel.style.overflow = "hidden";
    panel.style.willChange = "height, opacity, transform";
    panel.style.transition = `height ${DURATION}ms ${EASING}, opacity ${Math.round(DURATION * 0.9)}ms ${EASING}, transform ${DURATION}ms ${EASING}`;

    if (item.open) {
      panel.style.height = "auto";
      panel.style.opacity = "1";
      panel.style.transform = "translateY(0)";
    } else {
      panel.style.height = "0px";
      panel.style.opacity = "0";
      panel.style.transform = "translateY(-4px)";
    }
  };

  const expandItem = (item: HTMLDetailsElement) => {
    const panel = getPanel(item);
    if (!panel || item.dataset.axAnimating === "true") return;

    item.dataset.axAnimating = "true";
    item.open = true;
    panel.style.height = "0px";
    panel.style.opacity = "0";
    panel.style.transform = "translateY(-4px)";

    requestAnimationFrame(() => {
      const targetHeight = panel.scrollHeight;
      panel.style.height = `${targetHeight}px`;
      panel.style.opacity = "1";
      panel.style.transform = "translateY(0)";

      const onEnd = (event: TransitionEvent) => {
        if (event.propertyName !== "height") return;
        panel.style.height = "auto";
        item.dataset.axAnimating = "false";
        panel.removeEventListener("transitionend", onEnd);
      };

      panel.addEventListener("transitionend", onEnd);
    });
  };

  const collapseItem = (item: HTMLDetailsElement) => {
    const panel = getPanel(item);
    if (!panel || item.dataset.axAnimating === "true" || !item.open) return;

    item.dataset.axAnimating = "true";
    const startHeight = panel.scrollHeight;
    panel.style.height = `${startHeight}px`;
    panel.style.opacity = "1";
    panel.style.transform = "translateY(0)";
    void panel.offsetHeight;

    requestAnimationFrame(() => {
      panel.style.height = "0px";
      panel.style.opacity = "0";
      panel.style.transform = "translateY(-4px)";

      const onEnd = (event: TransitionEvent) => {
        if (event.propertyName !== "height") return;
        item.open = false;
        item.dataset.axAnimating = "false";
        panel.removeEventListener("transitionend", onEnd);
      };

      panel.addEventListener("transitionend", onEnd);
    });
  };

  const setupAccordions = () => {
    document.querySelectorAll("[data-ax-accordion]").forEach((accordion) => {
      if (!(accordion instanceof HTMLElement)) return;
      if (accordion.dataset.axAccordionBound === "true") return;

      accordion.dataset.axAccordionBound = "true";
      const allowMultiple = accordion.dataset.allowMultiple === "true";

      accordion.querySelectorAll("details[data-ax-accordion-item]").forEach((item) => {
        if (!(item instanceof HTMLDetailsElement)) return;
        preparePanel(item);

        const summary = item.querySelector("summary");
        if (!(summary instanceof HTMLElement)) return;

        summary.addEventListener("click", (event) => {
          event.preventDefault();
          if (item.dataset.axAnimating === "true") return;

          if (item.open) {
            collapseItem(item);
            return;
          }

          if (!allowMultiple) {
            accordion.querySelectorAll("details[data-ax-accordion-item]").forEach((otherItem) => {
              if (!(otherItem instanceof HTMLDetailsElement) || otherItem === item) return;
              collapseItem(otherItem);
            });
          }

          expandItem(item);
        });
      });
    });
  };

  setupAccordions();
  document.addEventListener("DOMContentLoaded", setupAccordions);
  document.addEventListener("astro:page-load", setupAccordions);
</script>
