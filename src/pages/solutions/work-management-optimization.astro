---
import Layout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import '../../styles/global.css';
---

<Layout>
  <Section>
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-600">Solutions</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Work Management Optimization</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">This is placeholder content for Work Management Optimization.</p>
      <p class="mt-4 text-slate-600">Replace this text with your final workflow design, controls, and governance details.</p>
    </div>
  </Section>
</Layout>
