---
import Layout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import "../styles/global.css";
import Slider from "../components/ui/Slider.astro";
import { slides, sliderConfig } from "../data/slider";
import { testimonials } from "../data/ui/testimonial";
import { cards, consultingServices } from "../data/ui/card";
import HeroBanner from "../components/ui/HeroBanner.astro";
import Heading from "../components/ui/Heading.astro";
import Testimonial from "../components/ui/Testimonial.astro";

---

<Layout>
	<div
		class="max-w-9xl mx-auto text-center text-shadow-md text-shadow-neutral-950"
	>
		<HeroBanner image="/assets/images/hmpg-hero.jpg">
			<h1
				class="text-6xl font-medium leading-tight text-white lg:text-6xl"
			>
				Analytics-Driven
				<span class="block text-white"> Reliability Improvement </span>
			</h1>

			<p class="mt-6 max-w-2xl mx-auto text-3xl leading-8 text-slate-100">
				Streamlined technology software, processes, and training,
				delivering total control over managing the lifecycle of your
				assets.
			</p>

			<!-- <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/contact">
            Contact Us
        </Button>

        <Button href="/services" variant="secondary">
            Our Services
        </Button>
    </div> -->
		</HeroBanner>
	</div>

	<Section>
		<div class="grid lg:grid-cols-2 xl:grid-cols-3 gap-4">
			<article>
				<p
					class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-700"
				>
					<span
						class="mr-3 inline-block h-0.5 w-10 bg-accent align-middle"
					></span>
					AT A GLANCE
				</p>
				<h1 class="text-4xl mb-2 font-semibold">
					<span class="block text-brand"> Asset Analytix </span><span
						class="block text-accent"
						>Solutions
					</span>
				</h1>

				<p>
					The Asset Analytix team represents full-scale, diverse
					subject matter expertise for a complete end-to-end solution
					across your entire organization involved with Enterprise
					Asset Management.
				</p>
				<p>
					Our Analytics-Driven Improvement Management System provides
					everything needed from detailed problem
					identification/verification, solution design, training,
					coaching, 360Navigator Technology Software, and the
					essential services around reporting and analytics for
					sustainable change.
				</p>
			</article>
			<article class="bg-slate-100 p-6">
				<h2 class="text-2xl mb-2 font-semibold">
					<span class="block text-accent">
						PM Baselining and CMMS Assessment Special Offers
					</span>
				</h2>

				<p>
					Asset Analytix is pleased to offer two powerful solutions to
					evaluate the most critical aspects of your Reliability and
					Asset Management program and a Deep-Dive Baselining training
					event for your PM Program.
				</p>
				<p>
					Together, these solutions offer a comprehensive approach to
					improving asset management and reliability across your
					organization. By evaluating your current strategies and
					providing targeted training, Asset Analytix helps you make
					informed decisions, increase uptime, streamline processes,
					optimize asset strategies, reduce operational costs,
					identify performance gaps, and enhance asset reliability.
				</p>
				<Button
					href="/specialoffers"
					class="mt-2 uppercase"
					variant="secondary"
					size="md">View The Offer</Button
				>
			</article>

			<article class="pt-0">
				<!-- <h2 class="mb-5 text-3xl font-semibold text-slate-900">1. Slider</h2> -->
				<Slider
					slides={slides}
					autoPlay={sliderConfig.autoPlay}
					interval={sliderConfig.interval}
					showDots={sliderConfig.showDots}
					showArrows={sliderConfig.showArrows}
					altFallback={sliderConfig.altFallback}
				/>
			</article>
		</div>
	</Section>

	<Section
		class="bg-[url(/assets/images/bgn-industries.png)] bg-cover bg-center bg-no-repeat"
	>
		<!-- <h2 class="mb-5 text-3xl font-semibold text-slate-900">2. Cards</h2> -->
		<div
			class="grid gap-6 md:grid-cols-2 xl:grid-cols-3 *:last:col-span-3 max-w-7xl mx-auto"
		>
			{cards.map((card) => <Card {...card} />)}

			<Card {...consultingServices} className="col-span-3" />
		</div>
	</Section>

	<div class="hero">
		<div class="hero__content max-w-7xl mx-auto">
			<p class="mb-3 text-xs font-semibold uppercase tracking-[0.14em] text-white mt-0!">
				<span
					class="mr-3 inline-block h-0.5 w-10 bg-accent align-middle"
				></span> GREAT REVIEWS FOR OUR SERVICES
			</p>

			<Heading level={2}>
				<span class="text-white">Real Results </span>
				<span class="block text-white">
					Client Praise
				</span>
			</Heading>
<section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 max-w-7xl mx-auto">
	
		<Testimonial {...testimonials[0]} />
		<Testimonial {...testimonials[1]} />
		<Testimonial {...testimonials[2]} />
	
</section>

		</div>
	</div>

	<!-- <Section class="mt-16">
		<div class="grid gap-6 lg:grid-cols-3">
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">
					Modern Asset Intelligence
				</h2>
				<p class="mt-3 text-slate-600">
					Deliver faster decisions with data-driven asset analytics,
					predictive insights, and connected operations.
				</p>
				<Button href="/solutions" class="mt-6">Explore solutions</Button
				>
			</Card>
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">
					Consulting & advisory
				</h2>
				<p class="mt-3 text-slate-600">
					Partner with our team to modernize asset management, reduce
					risk, and accelerate digital transformation.
				</p>
				<Button href="/consulting" variant="secondary" class="mt-6"
					>See consulting</Button
				>
			</Card>
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">
					Resources for teams
				</h2>
				<p class="mt-3 text-slate-600">
					Find guides, case studies, and product insights to support
					asset analytics adoption across your organization.
				</p>
				<Button href="/resources" variant="secondary" class="mt-6"
					>View resources</Button
				>
			</Card>
		</div>
	</Section> -->
</Layout>

<style>
	.hero {
		position: relative;
		min-height: 320px;
		background: rgb(39, 93, 122) url("/assets/images/bgn-quotes.jpg");
		/* background-image: 
			linear-gradient(90deg, rgba(39, 93, 122, 0.5), rgba(14, 57, 83, 0.5)), 
			url('/assets/images/bgn-quotes.jpg'); */
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		background-attachment: scroll;
		clip-path: polygon(0 0, 100% 25%, 100% 100%, 0% 100%);
	}

	.hero__content {
		/* padding: 80px; */
		color: white;
	}
</style>
