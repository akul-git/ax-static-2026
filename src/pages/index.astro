---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import "../styles/global.css";
---

<Layout>
	<Welcome />
<div class="hero">
	<div class="hero__content">
<Card>
				
	<h2 class="text-xl font-semibold text-slate-900">Modern Asset Intelligence</h2>
				<p class="mt-3 text-slate-600">Deliver faster decisions with data-driven asset analytics, predictive insights, and connected operations.</p>
				<Button href="/solutions" class="mt-6">Explore solutions</Button>
				<span style="font-family: BusinessPeople">ABC</span>
				
			</Card>

	</div>
</div>
	<Section class="mt-16">
		<div class="grid gap-6 lg:grid-cols-3">
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">Modern Asset Intelligence</h2>
				<p class="mt-3 text-slate-600">Deliver faster decisions with data-driven asset analytics, predictive insights, and connected operations.</p>
				<Button href="/solutions" class="mt-6">Explore solutions</Button>
			</Card>
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">Consulting & advisory</h2>
				<p class="mt-3 text-slate-600">Partner with our team to modernize asset management, reduce risk, and accelerate digital transformation.</p>
				<Button href="/consulting" variant="secondary" class="mt-6">See consulting</Button>
			</Card>
			<Card>
				<h2 class="text-xl font-semibold text-slate-900">Resources for teams</h2>
				<p class="mt-3 text-slate-600">Find guides, case studies, and product insights to support asset analytics adoption across your organization.</p>
				<Button href="/resources" variant="secondary" class="mt-6">View resources</Button>
			</Card>
		</div>
	</Section>
</Layout>

<style>
	.hero {
  position: relative;
  min-height: 320px;
  background:
    linear-gradient(
      90deg,
      rgba(39,93,122,.95),
      rgba(14,57,83,.95)
    );

  /* clip-path: polygon(
    0 0,
    100% 45px,
    100% calc(100% - 45px),
    0 100%
  ); */

  clip-path: polygon(0 46%, 100% 18%, 100% 100%, 0% 100%);
}

.hero__content {
  padding: 80px;
  color: white;
}
	</style>