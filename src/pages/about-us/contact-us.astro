---
import Layout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import ContactForm from '../../components/ui/ContactForm.astro';
import '../../styles/global.css';

const status = Astro.url.searchParams.get("status") || "";
const isSuccess = status === "submitted";

const errorMessages = {
  invalid: "Please complete all required fields with valid information.",
  captcha_error: "CAPTCHA verification failed. Please try again.",
  rate_limited: "Too many attempts. Please wait a few minutes and retry.",
  origin_error: "Request origin could not be verified.",
  payload_too_large: "Submission payload is too large.",
  delivery_not_configured: "Form delivery is not configured yet. Set SMTP and recipient environment variables.",
  server_error: "Something went wrong on our side. Please try again shortly.",
};

const errorMessage = errorMessages[status as keyof typeof errorMessages] || "";
---

<Layout title="Contact Us">
  <Section>
    <div class="grid gap-10 xl:grid-cols-[0.95fr_1.35fr] xl:items-start">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-sky-600">About Us</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Contact Us</h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">Use the form to connect with our team about consulting, solutions, workshops, or a product demonstration.</p>
        <div class="mt-8 space-y-4 text-slate-700">
          <p><strong>Email:</strong> info@assetanalytix.com</p>
          <p><strong>Phone:</strong> +1 (800) 555-0140</p>
          <p><strong>Response time:</strong> Typically within one business day.</p>
        </div>
        <div class="mt-8 rounded-xl border border-slate-200 bg-white p-5 text-sm leading-7 text-slate-600 shadow-sm">
          <p class="font-semibold text-slate-900">Secure deployment note</p>
          <p class="mt-2">This form UI is ready for a same-origin secure backend endpoint. Connect a real CAPTCHA provider and server-side validation before going live.</p>
        </div>
      </div>

      <div>
        {isSuccess ? (
          <p class="mb-5 rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
            Thank you. Your message has been received.
          </p>
        ) : errorMessage ? (
          <p class="mb-5 rounded-md border border-rose-300 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">
            {errorMessage}
          </p>
        ) : null}

        <ContactForm action="/api/contact" />
      </div>
    </div>
  </Section>
</Layout>
