---
import Layout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import '../styles/global.css';
---

<Layout>
  <Section>
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-600">About Us</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">A team focused on asset performance and analytics transformation.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">We help asset owners and operators move from reactive maintenance to predictive, data-driven decision making.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="/book-demo">Book a call</Button>
        <Button href="/resources" variant="secondary">Explore resources</Button>
      </div>
    </div>
  </Section>

  <Section class="bg-slate-100">
    <div class="grid gap-6 lg:grid-cols-3">
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Industry expertise</h2>
        <p class="mt-3 text-slate-600">Deep experience in reliability engineering, asset management, and digital operations.</p>
      </Card>
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Data-first solutions</h2>
        <p class="mt-3 text-slate-600">We build scalable analytics and insights for asset-intensive organizations.</p>
      </Card>
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Collaborative delivery</h2>
        <p class="mt-3 text-slate-600">Partnering with teams to turn strategy into measurable outcomes.</p>
      </Card>
    </div>
  </Section>
</Layout>
