---
import Layout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import '../styles/global.css';
---

<Layout title="Our Approach">
  <Section>
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-600">Company</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Our Approach</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">This is placeholder content for your Our Approach page.</p>
      <p class="mt-4 text-slate-600">Replace this section with your final methodology, process model, and principles.</p>
    </div>
  </Section>
</Layout>
