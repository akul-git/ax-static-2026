---
import Layout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Slider from "../components/ui/Slider.astro";
import Card from "../components/ui/Card.astro";
import Table from "../components/ui/Table.astro";
import FlippingCard from "../components/ui/FlippingCard.astro";
import HeroBanner from "../components/ui/HeroBanner.astro";
import Blockquote from "../components/ui/Blockquote.astro";
import List from "../components/ui/List.astro";
import Video from "../components/ui/Video.astro";
import Accordion from "../components/ui/Accordion.astro";
import BookDemo from "../components/ui/BookDemo.astro";
import Testimonial from "../components/ui/Testimonial.astro";
import ClientLogoSlider from "../components/ui/ClientLogoSlider.astro";
import Button from "../components/ui/Button.astro";
import siteContent from "../data/site-content.json";
import { cards, standaloneCard } from "../data/ui/card";
import "../styles/global.css";

const slides = [
  {
    src: "/android-chrome-512x512.png",
    alt: "Award style reference",
    caption: "Asset Analytix recognition",
  },
  {
    src: "/apple-touch-icon.png",
    alt: "Brand mark",
    caption: "Brand moment",
  },
  {
    src: "/favicon-32x32.png",
    alt: "Icon sample",
    caption: "Compact icon sample",
  },
];

const headers = ["Initiative", "Timeline", "Outcome", "Owner"];
const rows = [
  ["CMMS Program Optimization", "6 weeks", "Data quality score +34%", "Operations"],
  ["PM Strategy Review", "4 weeks", "PM cost reduced by 21%", "Reliability"],
  ["Reliability Analytics", "8 weeks", "Downtime reduced by 17%", "Maintenance"],
  ["Workflow Standardization", "5 weeks", "Planning compliance 93%", "Work Mgmt"],
];
const footer = ["Total Programs", "4", "Average Improvement", "+24%"];

const bulletItems = [
  "Discover and prioritize critical data issues.",
  "Align maintenance policy with reliability goals.",
  "Deploy reporting standards with KPI ownership.",
];

const numberedItems = [
  "Assess current state and maturity.",
  "Design optimized workflows and governance.",
  "Enable teams with practical playbooks.",
];

const iconItems = [
  "Remote workshops for distributed teams.",
  "Hands-on pilot with measurable targets.",
  "Weekly executive visibility and progress updates.",
];

const accordionItems = [
  {
    title: "360 Precision Assessment",
    content:
      "A complete baseline of asset, process, and planning practices to reveal where performance can be accelerated first.",
  },
  {
    title: "Measures Architecture",
    content:
      "Define a practical KPI model that links operations, maintenance, and leadership decisions to one shared execution rhythm.",
  },
  {
    title: "Baselining Pilot Events",
    content:
      "At AX, baselining is a process, a series of actions, and a discovery cycle. Each two-week pilot becomes a micro experience of a full-scale solution.",
    bullets: [
      "EAM Program Assessment",
      "Reliability Strategies / PMO",
      "Work Management P&S",
      "Storeroom / Procurement",
      "I&E / Calibration",
      "Production Op-Ex",
    ],
  },
  {
    title: "Solution Deployment",
    content: "Execute with structured workshops, accountable owners, and timeline-driven implementation checkpoints.",
  },
  {
    title: "Data & Analytics",
    content:
      "Operationalize analytics across planning, execution, and reliability so teams can act on real-time priorities with confidence.",
  },
];

const clientLogos = Array.isArray(siteContent.clientLogos) ? siteContent.clientLogos : [];
const showcaseTestimonial = Array.isArray(siteContent.testimonials) && siteContent.testimonials.length > 0
  ? siteContent.testimonials[0]
  : null;
---

<Layout title="Components Showcase">
  <Section>
    <div class="mx-auto max-w-5xl text-center">
      <p class="text-sm uppercase tracking-[0.18em] text-sky-600">Design System</p>
      <h1 class="mt-3 text-5xl font-semibold tracking-tight text-slate-900">Reusable Components Showcase</h1>
      <p class="mt-4 text-lg text-slate-600">
        This page demonstrates the reusable UI components available for sitewide use.
      </p>
    </div>
  </Section>

  <Section class="pt-0">
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">1. Slider</h2>
    <Slider slides={slides} interval={3500} />
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">2. Cards</h2>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {cards.map((card) => (
        <Card {...card} />
      ))}

      <Card {...standaloneCard} />
      <!-- <Card {...wmo} /> -->
    </div>
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">3. Table</h2>
    <Table caption="Program Performance Summary" headers={headers} rows={rows} footer={footer} />
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">4. Flipping Card</h2>
    <div class="grid gap-6 md:grid-cols-2">
      <FlippingCard
        frontTitle="Full Immersion\nPilot Project"
        frontSubtitle="Flip to learn more"
        backText="Experience the total optimization process through a practical on-site or remote pilot."
      />
      <FlippingCard
        frontTitle="Remote\nWorkshops"
        frontSubtitle="Hover to reveal"
        backText="Hands-on facilitation to align teams, tighten planning quality, and scale execution standards."
        href="/consulting/remote-workshops"
      />
    </div>
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">5. Hero and Banner</h2>
  </Section>

  <!-- <div class="space-y-8">
    <HeroBanner
      variant="hero"
      title="Analytics-Driven Reliability Improvement"
      subtitle="Streamlined technology, process, and training across your asset lifecycle."
      backgroundImage="/android-chrome-512x512.png"
      overlay="linear-gradient(90deg, rgba(15,23,42,0.65), rgba(15,23,42,0.35))"
    >
      <Button href="/solutions" class="mt-2">Explore Solutions</Button>
    </HeroBanner>

    <HeroBanner
      variant="banner"
      title="Blended PM Optimization"
      subtitle="Increase uptime, reduce PM cost, and accelerate execution quality."
      backgroundImage="/apple-touch-icon.png"
      overlay="linear-gradient(90deg, rgba(2,132,199,0.55), rgba(15,23,42,0.35))"
    />
  </div> -->

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">6. Blockquote</h2>
    <Blockquote
      variant="quote"
      quote="This is the fastest, most accurate and practical PM Optimization System available."
      textColor="text-sky-700"
      class="bg-slate-100"
    />
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">7. List Variations</h2>
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="text-2xl font-semibold text-slate-900">Bullet</h3>
        <List items={bulletItems} class="mt-4" />
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="text-2xl font-semibold text-slate-900">Numbered</h3>
        <List variant="number" items={numberedItems} class="mt-4" />
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h3 class="text-2xl font-semibold text-slate-900">Custom Icon</h3>
        <List variant="icon" items={iconItems} icon="/favicon-32x32.png" iconAlt="Check icon" class="mt-4" />
      </div>
    </div>
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">8. Accordion</h2>
    <Accordion items={accordionItems} />
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">9. Section Wrapper</h2>
    <Section class="rounded-2xl border border-slate-200 bg-white py-10">
      <div class="text-center">
        <h3 class="text-3xl font-semibold text-slate-900">Nested Content in Section</h3>
        <p class="mt-3 text-lg text-slate-600">This demonstrates the Section wrapper for consistent spacing and layout structure.</p>
      </div>
    </Section>
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">10. Video and Audio</h2>
    <div class="grid gap-6 lg:grid-cols-2">
      <Video
        title="Asset Optimization Overview"
        src="https://media.w3.org/2010/05/sintel/trailer_hd.mp4"
        poster="/android-chrome-512x512.png"
        caption="MediaElement.js powered video playback."
      />
      <Video
        title="Program Briefing Audio"
        src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"
        mediaType="audio"
        caption="Same reusable component rendering MP3 audio playback."
      />
    </div>
  </Section>

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">11. Book-a-Demo CTA</h2>
    <BookDemo
      backgroundImage="/android-chrome-512x512.png"
      buttonLabel="BOOK A DEMO"
      href="/book-demo"
      minHeight="20rem"
    />
  </Section>

  <!-- <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">12. Testimonial</h2>
    {showcaseTestimonial ? <Testimonial {...showcaseTestimonial} /> : <Testimonial />}
  </Section> -->

  <Section>
    <h2 class="mb-5 text-3xl font-semibold text-slate-900">13. Client Logo Slider</h2>
    <ClientLogoSlider logos={clientLogos} interval={3200} mobileItemsPerSlide={2} tabletItemsPerSlide={3} desktopItemsPerSlide={4} />
  </Section>
</Layout>
