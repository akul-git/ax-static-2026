---
import Layout from '../layouts/BaseLayout.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import '../styles/global.css';
---

<Layout>
  <Section>
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm uppercase tracking-[0.3em] text-sky-600">Consulting</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-900">Build a practical roadmap for asset modernization.</h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">Our advisory services help teams prioritize digital transformation, capture value, and improve asset performance through proven strategies.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="/book-demo">Schedule a consultation</Button>
        <Button href="/resources" variant="secondary">View resources</Button>
      </div>
    </div>
  </Section>

  <Section class="bg-slate-100">
    <div class="grid gap-6 lg:grid-cols-3">
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Strategic planning</h2>
        <p class="mt-3 text-slate-600">Align your asset program with business goals and operational priorities.</p>
      </Card>
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Implementation support</h2>
        <p class="mt-3 text-slate-600">Accelerate adoption with tactical guidance and hands-on support.</p>
      </Card>
      <Card>
        <h2 class="text-xl font-semibold text-slate-900">Change enablement</h2>
        <p class="mt-3 text-slate-600">Help teams adopt new workflows, dashboards, and decision-making practices.</p>
      </Card>
    </div>
  </Section>
</Layout>
