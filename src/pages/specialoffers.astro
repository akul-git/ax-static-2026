---
import Layout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const formAction = String(import.meta.env.PUBLIC_CONTACT_FORM_ACTION || "");
---

<Layout title="Special Offers">
  <section class="special-offers">
    <div class="offers-left">
      <h1 class="offers-title">Special Offers</h1>
      <p class="offers-copy">
        Asset Analytix is pleased to offer two powerful solutions to evaluate the most critical aspects of your
        Reliability and Asset Management program and a Deep-Dive Baselining training event for your PM Program.
        Once registered, you will receive an email with links to get started.
      </p>

      <div class="offer-card-grid">
        <article class="offer-card" aria-label="PM Baselining Analysis">
          <h2 class="offer-card-title">PM Baselining<br />Analysis</h2>
          <p class="offer-card-subtitle">Register NOW for your</p>
          <p class="offer-card-logo" aria-hidden="true">360 Navigator</p>
          <p class="offer-card-cta">FLIP TO LEARN MORE</p>
        </article>

        <article class="offer-card" aria-label="Assess your CMMS Assessment">
          <h2 class="offer-card-title">Assess your CMMS<br />Assessment</h2>
          <p class="offer-card-subtitle">Register NOW for your</p>
          <p class="offer-card-logo" aria-hidden="true">360 Navigator</p>
          <p class="offer-card-cta">FLIP TO LEARN MORE</p>
        </article>
      </div>
    </div>

    <aside class="offers-form-wrap" aria-label="Special offer registration form">
      <h2 class="form-title">Register for Your Special Offer</h2>
      {!formAction ? (
        <p class="mb-4 rounded-sm border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-800">
          Form endpoint is not configured. Set <strong>PUBLIC_CONTACT_FORM_ACTION</strong> to enable submissions.
        </p>
      ) : null}

      <form class="offer-form" method="post" action={formAction} accept-charset="UTF-8">
        <input type="hidden" name="form_name" value="special-offers" />
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        <label for="first-name">First name<span class="req">*</span></label>
        <input id="first-name" name="firstName" type="text" required />

        <label for="last-name">Last name<span class="req">*</span></label>
        <input id="last-name" name="lastName" type="text" required />

        <label for="company-name">Company name</label>
        <input id="company-name" name="companyName" type="text" />

        <label for="job-title">Job title</label>
        <input id="job-title" name="jobTitle" type="text" />

        <label for="work-email">Work email<span class="req">*</span></label>
        <input id="work-email" name="workEmail" type="email" required />

        <label for="phone-number">Phone number</label>
        <input id="phone-number" name="phone" type="tel" />

        <button type="submit" class="submit-btn" disabled={!formAction}>Submit</button>
      </form>
    </aside>
  </section>
</Layout>

<style>
  .special-offers {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(320px, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .offers-title {
    margin: 0;
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    line-height: 0.98;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #1a1a1a;
  }

  .offers-copy {
    margin: 1rem 0 0;
    max-width: 64ch;
    font-size: 1.05rem;
    line-height: 1.55;
    color: #111827;
  }

  .offer-card-grid {
    margin-top: 2rem;
    display: grid;
    gap: 1.8rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .offer-card {
    min-height: 460px;
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    background: #f5f6f8;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.75rem 1.25rem;
  }

  .offer-card-title {
    margin: 0;
    font-size: clamp(2rem, 2.6vw, 2.35rem);
    line-height: 1.05;
    font-weight: 500;
    color: #2a7ebb;
  }

  .offer-card-subtitle {
    margin: 1.15rem 0 0;
    font-size: 2rem;
    line-height: 1;
    color: #2a7ebb;
    font-weight: 400;
  }

  .offer-card-logo {
    margin: 0.8rem 0 0;
    font-size: 2.55rem;
    line-height: 1;
    color: #2a7ebb;
    font-weight: 300;
    letter-spacing: -0.03em;
  }

  .offer-card-cta {
    margin: 1.8rem 0 0;
    font-size: 1.05rem;
    color: #303030;
    letter-spacing: 0.01em;
  }

  .offers-form-wrap {
    background: #e5e7eb;
    border-radius: 0;
    padding: 1.3rem 1.25rem 1.5rem;
  }

  .form-title {
    margin: 0;
    color: #2a7ebb;
    font-size: clamp(2rem, 2.2vw, 2.4rem);
    line-height: 1.2;
    font-weight: 400;
  }

  .offer-form {
    margin-top: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
  }

  .offer-form label {
    font-size: 1.6rem;
    color: #0f172a;
  }

  .req {
    color: #e23a3a;
  }

  .offer-form input {
    border: 1px solid #b8c1cc;
    background: #f2f4f7;
    border-radius: 2px;
    padding: 0.45rem 0.5rem;
    height: 42px;
    outline: none;
    font-size: 1rem;
    color: #0f172a;
  }

  .offer-form input:focus {
    border-color: #2a7ebb;
    box-shadow: 0 0 0 2px rgb(42 126 187 / 20%);
  }

  .submit-btn {
    margin-top: 0.6rem;
    width: fit-content;
    min-width: 92px;
    border: 0;
    border-radius: 4px;
    background: #f17456;
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.55rem 1rem;
    cursor: pointer;
  }

  .submit-btn:hover {
    background: #ea6545;
  }

  .submit-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  @media (max-width: 1100px) {
    .special-offers {
      grid-template-columns: 1fr;
    }

    .offers-form-wrap {
      max-width: 520px;
    }
  }

  @media (max-width: 760px) {
    .offer-card-grid {
      grid-template-columns: 1fr;
    }

    .offer-card {
      min-height: 360px;
    }
  }
</style>
