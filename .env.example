# Comma-separated extra origins allowed to post to /api/contact.
# Leave empty to only allow same-origin.
ALLOWED_ORIGINS=

# CAPTCHA settings (optional).
# Set CAPTCHA_PROVIDER to "hcaptcha" to use hCaptcha verification.
# Otherwise, set RECAPTCHA_SECRET_KEY for Google reCAPTCHA verification.
CAPTCHA_PROVIDER=
HCAPTCHA_SECRET=
RECAPTCHA_SECRET_KEY=

# SMTP delivery for contact submissions (required for fully working form).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Contact form recipient and sender identity.
CONTACT_FORM_TO=
CONTACT_FORM_FROM=
