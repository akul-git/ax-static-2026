# Comma-separated extra origins allowed to post to /api/contact.
# Leave empty to only allow same-origin.
ALLOWED_ORIGINS=

# Public endpoint for static form submissions (used by Contact and Special Offers pages).
# Example (Formspree): https://formspree.io/f/your-form-id
PUBLIC_CONTACT_FORM_ACTION=

# CAPTCHA settings (optional).
# Set CAPTCHA_PROVIDER to "hcaptcha" to use hCaptcha verification.
# Otherwise, set RECAPTCHA_SECRET_KEY for Google reCAPTCHA verification.
CAPTCHA_PROVIDER=
HCAPTCHA_SECRET=
RECAPTCHA_SECRET_KEY=
PUBLIC_CAPTCHA_PROVIDER=
PUBLIC_HCAPTCHA_SITE_KEY=
PUBLIC_RECAPTCHA_SITE_KEY=

# SMTP delivery for contact submissions (required for fully working form).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Contact form recipient and sender identity.
CONTACT_FORM_TO=
CONTACT_FORM_FROM=
